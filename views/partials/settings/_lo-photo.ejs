    <!-- Loan Officer Photo -->
    <div class="calc-section">
      <h2>Loan Officer Photo</h2>
      <p class="settings-help">
        Upload a professional headshot. This appears on the Cover Letter beside your signature.
      </p>

      <% var loPhoto = config.loPhoto || ''; %>
      <% if (loPhoto) { %>
        <div class="settings-logo-preview u-mb-md">
          <img src="<%= loPhoto %>" alt="Loan Officer" style="width:100px;height:100px;object-fit:cover;border-radius:50%;border:2px solid var(--color-gray-200);">
        </div>
      <% } %>

      <form action="/settings/lo-photo" method="POST" enctype="multipart/form-data">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <div class="form-grid u-grid-1-auto">
          <div class="form-group">
            <label>Photo (PNG, JPG, WebP — max 2MB)</label>
            <input type="file" name="loPhoto" accept="image/png,image/jpeg,image/webp" required>
          </div>
          <div class="form-group u-justify-end">
            <button type="submit" class="btn btn-primary">Upload Photo</button>
          </div>
        </div>
      </form>
    </div>
