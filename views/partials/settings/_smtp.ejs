    <!-- SMTP / Email Configuration -->
    <div class="calc-section">
      <h2>Email (SMTP) Configuration</h2>
      <p class="settings-help">
        Configure SMTP to enable emailing calculator results to clients. For Outlook use <code>smtp.office365.com</code> port <code>587</code>.
        For Gmail use <code>smtp.gmail.com</code> port <code>587</code> with an App Password.
      </p>

      <form action="/settings/smtp" method="POST">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <div class="form-grid">
          <div class="form-group">
            <label for="smtpHost">SMTP Host</label>
            <input type="text" id="smtpHost" name="smtp_host"
                   value="<%= config.smtp ? config.smtp.host : '' %>"
                   placeholder="smtp.office365.com">
          </div>
          <div class="form-group">
            <label for="smtpPort">Port</label>
            <input type="number" id="smtpPort" name="smtp_port"
                   value="<%= config.smtp ? config.smtp.port : '587' %>"
                   placeholder="587">
          </div>
        </div>
        <div class="form-grid u-mt-md">
          <div class="form-group">
            <label for="smtpUser">Username / Email</label>
            <input type="text" id="smtpUser" name="smtp_user"
                   value="<%= config.smtp ? config.smtp.user : '' %>"
                   placeholder="you@msfginfo.com">
          </div>
          <div class="form-group">
            <label for="smtpPass">Password / App Password</label>
            <input type="password" id="smtpPass" name="smtp_pass"
                   value="<%= config.smtp ? config.smtp.pass : '' %>"
                   placeholder="App password">
          </div>
        </div>
        <div class="form-grid u-mt-md">
          <div class="form-group">
            <label for="smtpFrom">From Address <span class="text-muted-light">(optional, defaults to username)</span></label>
            <input type="email" id="smtpFrom" name="smtp_from"
                   value="<%= config.smtp ? config.smtp.from : '' %>"
                   placeholder="noreply@msfginfo.com">
          </div>
        </div>
        <div class="action-bar">
          <button type="submit" class="btn btn-primary">Save SMTP Settings</button>
        </div>
      </form>
    </div>
