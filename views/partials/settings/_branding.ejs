    <!-- Current Logo Preview -->
    <div class="calc-section">
      <h2>Current Logo</h2>
      <div class="settings-logo-preview">
        <img src="<%= config.logo.src %>" alt="<%= config.logo.alt %>" data-max-width="<%= config.logo.width %>" onerror="this.outerHTML='<span class=text-muted>No logo uploaded yet</span>'">
      </div>
    </div>

    <!-- Upload New Logo -->
    <div class="calc-section">
      <h2>Upload Logo</h2>
      <form action="/settings/logo" method="POST" enctype="multipart/form-data">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <div class="form-grid u-grid-1-auto">
          <div class="form-group">
            <label>Logo Image (PNG, JPG, WebP — max 2MB)</label>
            <input type="file" name="logo" accept="image/png,image/jpeg,image/webp" required>
          </div>
          <div class="form-group u-justify-end">
            <button type="submit" class="btn btn-primary">Upload Logo</button>
          </div>
        </div>
      </form>
    </div>

    <!-- Site Configuration -->
    <div class="calc-section">
      <h2>Site Configuration</h2>
      <form action="/settings/update" method="POST">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <div class="form-grid">
          <div class="form-group">
            <label for="siteName">Site Name</label>
            <input type="text" id="siteName" name="siteName" value="<%= config.siteName %>">
          </div>
          <div class="form-group">
            <label for="companyName">Company Name</label>
            <input type="text" id="companyName" name="companyName" value="<%= config.companyName %>">
          </div>
          <div class="form-group">
            <label for="logoWidth">Logo Max Width (px)</label>
            <input type="number" id="logoWidth" name="logoWidth" value="<%= config.logo.width %>" min="40" max="400">
          </div>
        </div>
        <div class="action-bar">
          <button type="submit" class="btn btn-primary">Save Settings</button>
        </div>
      </form>
    </div>
