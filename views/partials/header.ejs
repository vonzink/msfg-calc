<header class="site-header">
  <div class="site-header__inner">
    <a href="/" class="site-header__brand">
      <img
        src="<%= site.logo.src %>"
        alt="<%= site.logo.alt %>"
        class="site-header__logo"
        style="max-width: <%= site.logo.width %>px;"
        onerror="this.style.display='none'"
      >
    </a>

    <nav class="site-header__nav">
      <a href="/" class="site-header__link<%= currentPath === '/' ? ' active' : '' %>">Hub</a>
      <a href="/workspace" class="site-header__link<%= currentPath === '/workspace' ? ' active' : '' %>">Workspace</a>
      <div class="site-header__dropdown">
        <button class="site-header__link site-header__dropdown-trigger">
          Calculators <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="site-header__dropdown-menu">
          <% categories.forEach(cat => { %>
            <div class="site-header__dropdown-group">
              <div class="site-header__dropdown-label"><%= cat.label %></div>
              <% calculators.filter(c => c.category === cat.id && !c.hideFromNav).forEach(calc => { %>
                <a href="/calculators/<%= calc.slug %>" class="site-header__dropdown-item">
                  <span class="site-header__dropdown-icon"><%= calc.icon %></span>
                  <%= calc.name %>
                </a>
              <% }) %>
            </div>
          <% }) %>
        </div>
      </div>
      <div class="site-header__dropdown">
        <button class="site-header__link site-header__dropdown-trigger">
          Programs <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="site-header__dropdown-menu">
          <div class="site-header__dropdown-group">
            <div class="site-header__dropdown-label">Conventional</div>
            <a href="https://selling-guide.fanniemae.com/sel/b/origination-through-closing" target="_blank" rel="noopener" class="site-header__dropdown-item">
              <span class="site-header__dropdown-icon">📘</span>
              Fannie Mae Selling Guide
            </a>
            <a href="https://yourhome.fanniemae.com/calculators-tools/loan-lookup" target="_blank" rel="noopener" class="site-header__dropdown-item">
              <span class="site-header__dropdown-icon">🔍</span>
              Fannie Mae Loan Lookup
            </a>
            <a href="https://ami-lookup-tool.fanniemae.com/" target="_blank" rel="noopener" class="site-header__dropdown-item">
              <span class="site-header__dropdown-icon">📍</span>
              AMI Lookup Tool
            </a>
            <a href="https://guide.freddiemac.com/" target="_blank" rel="noopener" class="site-header__dropdown-item">
              <span class="site-header__dropdown-icon">📗</span>
              Freddie Mac Guide
            </a>
            <a href="https://sf.freddiemac.com/working-with-us/affordable-lending/home-possible-eligibility-map" target="_blank" rel="noopener" class="site-header__dropdown-item">
              <span class="site-header__dropdown-icon">🗺️</span>
              Home Possible Eligibility Map
            </a>
          </div>
          <div class="site-header__dropdown-group">
            <div class="site-header__dropdown-label">VA</div>
            <a href="https://www.benefits.va.gov/homeloans/index.asp" target="_blank" rel="noopener" class="site-header__dropdown-item">
              <span class="site-header__dropdown-icon">🎖️</span>
              VA Home Loans
            </a>
            <a href="https://www.va.gov/vapubs/search_action.cfm?dType=2" target="_blank" rel="noopener" class="site-header__dropdown-item">
              <span class="site-header__dropdown-icon">📄</span>
              VA Publications
            </a>
            <a href="https://lgy.va.gov/lgyhub/" target="_blank" rel="noopener" class="site-header__dropdown-item">
              <span class="site-header__dropdown-icon">🏛️</span>
              LGY Hub
            </a>
            <a href="https://yourit.va.gov/csm?id=rlc_test_test&sysparam_card=lender_appraisal" target="_blank" rel="noopener" class="site-header__dropdown-item">
              <span class="site-header__dropdown-icon">📋</span>
              VA Appraisal Portal
            </a>
          </div>
          <div class="site-header__dropdown-group">
            <div class="site-header__dropdown-label">USDA</div>
            <a href="https://eligibility.sc.egov.usda.gov/eligibility/welcomeAction.do" target="_blank" rel="noopener" class="site-header__dropdown-item">
              <span class="site-header__dropdown-icon">🌾</span>
              USDA Eligibility Map
            </a>
          </div>
        </div>
      </div>
      <div class="site-header__dropdown">
        <button class="site-header__link site-header__dropdown-trigger<%= currentPath.startsWith('/handbook') || currentPath.startsWith('/processing') ? ' active' : '' %>">
          HR <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="site-header__dropdown-menu">
          <a href="/handbook" class="site-header__dropdown-item">
            <span class="site-header__dropdown-icon">📖</span>
            Employee Handbook
          </a>
          <a href="/processing/title" class="site-header__dropdown-item">
            <span class="site-header__dropdown-icon">📋</span>
            Processing
          </a>
          <a href="https://dashboard.msfgco.com/Calculators/File%20Browser/file-browser.html?library=forms" target="_blank" rel="noopener" class="site-header__dropdown-item">
            <span class="site-header__dropdown-icon">📝</span>
            HR Forms
          </a>
        </div>
      </div>
      <a href="/report" class="site-header__link site-header__report-link<%= currentPath === '/report' ? ' active' : '' %>" title="Session Report">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
        <span class="report-badge" id="reportBadge" style="display:none;">0</span>
      </a>
      <a href="/settings" class="site-header__link<%= currentPath === '/settings' ? ' active' : '' %>">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
      </a>
    </nav>

    <button class="site-header__mobile-toggle" id="mobileMenuToggle" aria-label="Toggle menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
  </div>
</header>
