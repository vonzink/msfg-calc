<div class="calc-page">
  <div class="calc-page__header">
    <h1>FHA Loan Calculator</h1>
    <p>Unified FHA purchase, refinance, and streamline analysis with UFMIP, NTB, and MISMO auto-fill.</p>
  </div>

  <div class="calc-page__body">

    <!-- MISMO Drop Zone -->
    <div class="mismo-drop" id="fhaMismoDrop">
      Drop a MISMO XML file here to auto-populate fields, or <strong>click to browse</strong>
      <input type="file" id="fhaMismoFile" accept=".xml,.mismo" class="u-hidden">
    </div>

    <!-- Section 1: Borrower & Property -->
    <div class="calc-section">
      <h2>Borrower &amp; Property</h2>

      <!-- Purchase / Refi Toggle -->
      <div class="fha-loan-toggle u-mb-md">
        <button type="button" class="fha-toggle-btn active" data-mode="purchase">Purchase</button>
        <button type="button" class="fha-toggle-btn" data-mode="refi">Refinance</button>
      </div>

      <div class="form-grid">
        <div class="form-group">
          <label>Borrower Name</label>
          <input type="text" id="fhaBorrowerName" placeholder="Auto-filled from MISMO">
        </div>
        <div class="form-group">
          <label>FHA Case ID</label>
          <input type="text" id="fhaCaseId" placeholder="Optional">
        </div>
      </div>
      <div class="form-grid u-mt-md">
        <div class="form-group">
          <label>Appraised Value</label>
          <input type="number" id="fhaAppraisedValue" step="0.01" placeholder="0.00">
        </div>
        <div class="form-group fha-purchase-only">
          <label>Purchase Price</label>
          <input type="number" id="fhaPurchasePrice" step="0.01" placeholder="0.00">
        </div>
        <div class="form-group">
          <label>Property Type</label>
          <select id="fhaPropertyType">
            <option value="sfr">SFR / PUD</option>
            <option value="2to4">2-4 Unit</option>
            <option value="manufactured">Manufactured Home</option>
          </select>
        </div>
      </div>
      <div class="form-grid u-mt-md">
        <div class="form-group">
          <label>County Loan Limit
            <span class="help-icon" data-help="FHA statutory loan limit for the county. Used as one of three max-mortgage calculations.">?</span>
          </label>
          <input type="number" id="fhaCountyLimit" step="1" value="541287">
          <small><a href="https://entp.hud.gov/idapp/html/hicostlook.cfm" target="_blank" rel="noopener">FHA Loan Limits</a></small>
        </div>
      </div>
    </div>

    <!-- Section 2: Current Loan (refi only) -->
    <div class="calc-section fha-refi-only" style="display:none;">
      <h2>Current Loan</h2>

      <div class="u-mb-md">
        <label class="form-check">
          <input type="checkbox" id="fhaIsExistingFha">
          Current loan is FHA (required for streamline)
        </label>
      </div>
      <div class="form-grid">
        <div class="form-group">
          <label>Current UPB
            <span class="help-icon" data-help="Outstanding principal balance on the existing mortgage.">?</span>
          </label>
          <input type="number" id="fhaCurrentUpb" step="0.01" placeholder="0.00">
        </div>
        <div class="form-group">
          <label>Current Interest Rate (%)
            <span class="help-icon" data-help="Interest rate on the existing loan. Used for NTB comparison.">?</span>
          </label>
          <input type="number" id="fhaCurrentRate" step="0.001" placeholder="e.g. 6.500">
        </div>
        <div class="form-group">
          <label>Current P&amp;I + MIP Payment
            <span class="help-icon" data-help="Current monthly principal, interest, and FHA MIP combined.">?</span>
          </label>
          <input type="number" id="fhaCurrentPayment" step="0.01" placeholder="0.00">
        </div>
      </div>
      <div class="form-grid u-mt-md">
        <div class="form-group">
          <label>Current Loan Type</label>
          <select id="fhaCurrentLoanType">
            <option value="fixed">Fixed Rate</option>
            <option value="arm">ARM</option>
          </select>
        </div>
        <div class="form-group">
          <label>Original FHA Loan Amount
            <span class="help-icon" data-help="Base loan amount from the original FHA loan (before UFMIP). Used to calculate UFMIP refund for streamline.">?</span>
          </label>
          <input type="number" id="fhaOriginalLoanAmount" step="0.01" placeholder="0.00">
        </div>
        <div class="form-group">
          <label>Original Loan Term</label>
          <select id="fhaOriginalTerm">
            <option value="30" selected>30 Years</option>
            <option value="25">25 Years</option>
            <option value="20">20 Years</option>
            <option value="15">15 Years</option>
          </select>
        </div>
        <div class="form-group">
          <label>Remaining Term
            <span class="help-icon" data-help="Auto-calculated from Original Term, First Payment Date, and Current Date. You can override manually.">?</span>
          </label>
          <input type="number" id="fhaRemainingTerm" step="1" placeholder="Auto-calculated">
          <small id="fhaRemainingTermNote"></small>
        </div>
      </div>
    </div>

    <!-- Section 3: Dates & Seasoning (refi only) -->
    <div class="calc-section fha-refi-only" style="display:none;">
      <h2>Loan Dates &amp; Seasoning</h2>
      <div class="form-grid">
        <div class="form-group">
          <label>FHA Endorsement Date
            <span class="help-icon" data-help="Original FHA loan endorsement date. Used for UFMIP refund calculation.">?</span>
          </label>
          <input type="date" id="fhaEndorsementDate">
        </div>
        <div class="form-group">
          <label>First Payment Due Date
            <span class="help-icon" data-help="Date of first payment on existing loan. Used for seasoning validation.">?</span>
          </label>
          <input type="date" id="fhaFirstPaymentDate">
        </div>
        <div class="form-group">
          <label>Current / Payoff Date</label>
          <input type="date" id="fhaCurrentDate">
          <small>Auto-populated with today's date</small>
        </div>
      </div>

      <!-- Seasoning Status Cards -->
      <div class="fha-seasoning-grid">
        <div class="fha-status-card" id="fhaPaymentsCard">
          <div class="fha-status-card__label">Payments Made</div>
          <div class="fha-status-card__value" id="fhaSeasoningPayments">&mdash;</div>
          <div class="fha-status-card__detail" id="fhaPaymentsDetail"></div>
        </div>
        <div class="fha-status-card" id="fhaDaysCard">
          <div class="fha-status-card__label">Days Since First Payment</div>
          <div class="fha-status-card__value" id="fhaSeasoningDays">&mdash;</div>
          <div class="fha-status-card__detail" id="fhaDaysDetail"></div>
        </div>
      </div>
    </div>

    <!-- Section 4: UFMIP Refund Table (refi only, collapsible) -->
    <div class="calc-section fha-refi-only" style="display:none;">
      <div class="fha-collapsible-header" data-target="fhaRefundBody">
        <h2>UFMIP Refund Table</h2>
        <span class="fha-collapse-icon collapsed">&#9660;</span>
      </div>
      <div class="fha-collapsible-body collapsed" id="fhaRefundBody">
        <p class="settings-help-sm u-mt-sm u-mb-sm">
          Refund applies only if existing FHA loan endorsed on/after <strong>Sept 1, 1983</strong>.
          Percentage based on months since endorsement. Values are editable.
        </p>
        <div class="u-overflow-x">
          <table class="fha-refund-table" id="fhaRefundTable">
            <thead>
              <tr>
                <th>Month</th><th>Refund</th>
                <th>Month</th><th>Refund</th>
                <th>Month</th><th>Refund</th>
              </tr>
            </thead>
            <tbody id="fhaRefundTableBody"></tbody>
          </table>
        </div>
        <div class="u-mt-sm">
          <button type="button" class="btn btn-sm" id="fhaResetRefundBtn">Reset to Default</button>
        </div>
      </div>
    </div>

    <!-- Section 5: Closing Costs (collapsible) -->
    <div class="calc-section">
      <div class="fha-collapsible-header" data-target="fhaCostsBody">
        <h2>Closing Costs (Itemized)</h2>
        <span class="fha-collapse-icon collapsed">&#9660;</span>
      </div>
      <div class="fha-collapsible-body collapsed" id="fhaCostsBody">
        <p class="settings-help-sm u-mb-sm">Itemize closing costs. All values default to $0.</p>

        <!-- Origination Charges -->
        <div class="fha-cost-group">
          <div class="fha-cost-group__title">Origination Charges</div>
          <div class="fha-cost-row">
            <label>Origination Fee</label>
            <input type="number" id="fhaCostOrigination" step="0.01" value="0" class="fha-cost-input">
          </div>
          <div class="fha-cost-row">
            <label>Processing Fee</label>
            <input type="number" id="fhaCostProcessing" step="0.01" value="0" class="fha-cost-input">
          </div>
          <div class="fha-cost-row">
            <label>Underwriting Fee</label>
            <input type="number" id="fhaCostUnderwriting" step="0.01" value="0" class="fha-cost-input">
          </div>
          <div class="fha-cost-row">
            <label>Discount Points</label>
            <input type="number" id="fhaCostPoints" step="0.01" value="0" class="fha-cost-input">
          </div>
        </div>

        <!-- Services You Cannot Shop For -->
        <div class="fha-cost-group">
          <div class="fha-cost-group__title">Services You Cannot Shop For</div>
          <div class="fha-cost-row">
            <label>Appraisal Fee</label>
            <input type="number" id="fhaCostAppraisal" step="0.01" value="0" class="fha-cost-input">
          </div>
          <div class="fha-cost-row">
            <label>Credit Report</label>
            <input type="number" id="fhaCostCredit" step="0.01" value="0" class="fha-cost-input">
          </div>
          <div class="fha-cost-row">
            <label>Flood Certification</label>
            <input type="number" id="fhaCostFlood" step="0.01" value="0" class="fha-cost-input">
          </div>
          <div class="fha-cost-row">
            <label>Tax Service Fee</label>
            <input type="number" id="fhaCostTaxService" step="0.01" value="0" class="fha-cost-input">
          </div>
        </div>

        <!-- Services You Can Shop For -->
        <div class="fha-cost-group">
          <div class="fha-cost-group__title">Services You Can Shop For</div>
          <div class="fha-cost-row">
            <label>Title Search / Exam</label>
            <input type="number" id="fhaCostTitleSearch" step="0.01" value="0" class="fha-cost-input">
          </div>
          <div class="fha-cost-row">
            <label>Title Insurance</label>
            <input type="number" id="fhaCostTitleInsurance" step="0.01" value="0" class="fha-cost-input">
          </div>
          <div class="fha-cost-row">
            <label>Owner's Title Insurance</label>
            <input type="number" id="fhaCostOwnersTitle" step="0.01" value="0" class="fha-cost-input">
          </div>
          <div class="fha-cost-row">
            <label>Settlement / Closing Fee</label>
            <input type="number" id="fhaCostSettlement" step="0.01" value="0" class="fha-cost-input">
          </div>
          <div class="fha-cost-row">
            <label>Recording Fees</label>
            <input type="number" id="fhaCostRecording" step="0.01" value="0" class="fha-cost-input">
          </div>
          <div class="fha-cost-row">
            <label>Attorney / Settlement</label>
            <input type="number" id="fhaCostAttorney" step="0.01" value="0" class="fha-cost-input">
          </div>
          <div class="fha-cost-row">
            <label>Wire Transfer Fee</label>
            <input type="number" id="fhaCostWire" step="0.01" value="0" class="fha-cost-input">
          </div>
        </div>

        <!-- Government Fees -->
        <div class="fha-cost-group">
          <div class="fha-cost-group__title">Government Fees</div>
          <div class="fha-cost-row">
            <label>Transfer Taxes</label>
            <input type="number" id="fhaCostTransferTax" step="0.01" value="0" class="fha-cost-input">
          </div>
        </div>

        <!-- Other -->
        <div class="fha-cost-group">
          <div class="fha-cost-group__title">Other Allowed Costs</div>
          <div class="fha-cost-row">
            <label>Survey</label>
            <input type="number" id="fhaCostSurvey" step="0.01" value="0" class="fha-cost-input">
          </div>
          <div class="fha-cost-row">
            <label>Pest Inspection</label>
            <input type="number" id="fhaCostPest" step="0.01" value="0" class="fha-cost-input">
          </div>
          <div class="fha-cost-row">
            <label>Other</label>
            <input type="number" id="fhaCostOther" step="0.01" value="0" class="fha-cost-input">
          </div>
        </div>

        <div class="fha-costs-total">
          <span class="fha-costs-total__label">Total Closing Costs</span>
          <span class="fha-costs-total__value" id="fhaTotalClosingCosts">$0.00</span>
        </div>

        <div class="fha-refi-only" style="display:none;">
          <div class="fha-cost-row u-mt-md">
            <label>Accrued Interest
              <span class="help-icon" data-help="Only if payoff is on/after payment due date. Do NOT include per diem beyond payoff.">?</span>
            </label>
            <input type="number" id="fhaAccruedInterest" step="0.01" value="0">
          </div>
        </div>

        <div class="fha-refi-only" style="display:none;">
          <p class="fha-costs-warning">
            Streamline: CANNOT finance late fees, escrows, prepaids, or payoffs other than existing FHA loan.
          </p>
        </div>
      </div>
    </div>

    <!-- Section 6: New Loan Parameters -->
    <div class="calc-section">
      <h2>New Loan Parameters</h2>
      <div class="form-grid">
        <div class="form-group">
          <label>New Interest Rate (%)
            <span class="help-icon" data-help="Proposed interest rate for the new FHA loan.">?</span>
          </label>
          <input type="number" id="fhaNewRate" step="0.001" placeholder="e.g. 5.750">
        </div>
        <div class="form-group">
          <label>New Loan Term (years)
            <span class="help-icon" data-help="Term in years for the new FHA loan.">?</span>
          </label>
          <select id="fhaNewTerm">
            <option value="30" selected>30 Years</option>
            <option value="25">25 Years</option>
            <option value="20">20 Years</option>
            <option value="15">15 Years</option>
          </select>
        </div>
        <div class="form-group">
          <label>New Loan Type</label>
          <select id="fhaNewLoanType">
            <option value="fixed">Fixed Rate</option>
            <option value="arm">ARM</option>
          </select>
        </div>
      </div>
      <div class="form-grid u-mt-md">
        <div class="form-group">
          <label>Requested Loan Amount
            <span class="help-icon" data-help="Enter the actual loan amount. Leave blank to use the maximum FHA-allowed amount.">?</span>
          </label>
          <input type="number" id="fhaRequestedLoanAmount" step="0.01" placeholder="Leave blank for max">
        </div>
      </div>
      <div class="u-mt-md">
        <label class="form-check">
          <input type="checkbox" id="fhaFinanceUfmip" checked>
          Finance UFMIP into loan amount
        </label>
      </div>
    </div>

    <!-- Section 7: Prepaids, Escrow & Credits -->
    <div class="calc-section">
      <h2>Prepaids, Escrow &amp; Credits</h2>
      <div class="form-grid">
        <div class="form-group">
          <label>Monthly Property Tax</label>
          <input type="number" id="fhaMonthlyTax" step="0.01" placeholder="0.00">
        </div>
        <div class="form-group">
          <label>Monthly Hazard Insurance</label>
          <input type="number" id="fhaMonthlyInsurance" step="0.01" placeholder="0.00">
        </div>
        <div class="form-group">
          <label>Monthly HOA</label>
          <input type="number" id="fhaMonthlyHoa" step="0.01" placeholder="0.00">
        </div>
      </div>
      <div class="form-grid u-mt-md">
        <div class="form-group">
          <label>Homeowner's Insurance Premium
            <span class="help-icon" data-help="Annual hazard insurance premium paid upfront at closing (typically 12 months).">?</span>
          </label>
          <input type="number" id="fhaHazardPremium" step="0.01" placeholder="0.00">
        </div>
        <div class="form-group">
          <label>Prepaid Interest
            <span class="help-icon" data-help="Per-diem interest from closing date to first payment date.">?</span>
          </label>
          <input type="number" id="fhaPrepaidInterest" step="0.01" placeholder="0.00">
        </div>
      </div>
      <div class="form-grid u-mt-md">
        <div class="form-group">
          <label>Tax Escrow (months)
            <span class="help-icon" data-help="Number of months of property tax held in escrow reserve at closing.">?</span>
          </label>
          <input type="number" id="fhaTaxEscrowMonths" step="1" value="3" min="0" max="12">
        </div>
        <div class="form-group">
          <label>Insurance Escrow (months)
            <span class="help-icon" data-help="Number of months of hazard insurance held in escrow reserve at closing.">?</span>
          </label>
          <input type="number" id="fhaInsEscrowMonths" step="1" value="3" min="0" max="12">
        </div>
      </div>
      <div class="form-grid u-mt-md">
        <div class="form-group">
          <label>Seller / Lender Credits
            <span class="help-icon" data-help="Seller concessions, lender credits, and other credits applied toward closing costs.">?</span>
          </label>
          <input type="number" id="fhaTotalCredits" step="0.01" placeholder="0.00">
        </div>
        <div class="form-group fha-refi-only" style="display:none;">
          <label>Escrow Refund from Current Loan
            <span class="help-icon" data-help="Escrow balance refunded by your current servicer after payoff (refi only).">?</span>
          </label>
          <input type="number" id="fhaEscrowRefund" step="0.01" placeholder="0.00">
        </div>
      </div>
    </div>

    <!-- Section 9: Results -->
    <div class="calc-section u-hidden" id="fhaResultsSection">
      <h2>Results</h2>

      <!-- Purchase Results (shown in purchase mode) -->
      <div id="fhaPurchaseResults" class="fha-purchase-only">
        <div class="fha-max-mortgage-grid">
          <div class="fha-max-card">
            <div class="fha-max-card__label">LTV Calculation</div>
            <div class="fha-max-card__value" id="fhaLtvCalc">&mdash;</div>
          </div>
          <div class="fha-max-card">
            <div class="fha-max-card__label">County Limit</div>
            <div class="fha-max-card__value" id="fhaStatutoryLimit">&mdash;</div>
          </div>
        </div>
        <div class="fha-max-result">
          <span>Maximum Base Loan:</span>
          <strong id="fhaMaxBaseLoan">&mdash;</strong>
        </div>

        <div class="fha-results-wrap u-mt-md">
          <table class="fha-results-table">
            <tbody>
              <tr class="fha-section-row"><td colspan="2">Loan Amount</td></tr>
              <tr>
                <td>Actual Base Loan</td>
                <td id="fhaActualBaseLoan">&mdash;</td>
              </tr>
              <tr>
                <td>New UFMIP (1.75%)</td>
                <td id="fhaNewUfmipAmt">&mdash;</td>
              </tr>
              <tr class="fha-subtotal-row">
                <td>Total Loan Amount</td>
                <td id="fhaTotalLoanAmt">&mdash;</td>
              </tr>
              <tr>
                <td>LTV</td>
                <td id="fhaLtv">&mdash;</td>
              </tr>
              <tr>
                <td>Annual MIP Rate</td>
                <td id="fhaMipRateDisplay">&mdash;</td>
              </tr>

              <tr class="fha-section-row"><td colspan="2">Monthly Payment</td></tr>
              <tr>
                <td>Principal &amp; Interest</td>
                <td id="fhaMonthlyPI">&mdash;</td>
              </tr>
              <tr>
                <td>Monthly MIP</td>
                <td id="fhaMonthlyMip">&mdash;</td>
              </tr>
              <tr>
                <td>Property Tax</td>
                <td id="fhaMonthlyTaxDisplay">&mdash;</td>
              </tr>
              <tr>
                <td>Hazard Insurance</td>
                <td id="fhaMonthlyInsDisplay">&mdash;</td>
              </tr>
              <tr>
                <td>HOA</td>
                <td id="fhaMonthlyHoaDisplay">&mdash;</td>
              </tr>
              <tr class="fha-total-row">
                <td>Total Monthly (PITI)</td>
                <td id="fhaTotalMonthly">&mdash;</td>
              </tr>

              <tr class="fha-section-row"><td colspan="2">Cash to Close</td></tr>
              <tr>
                <td>Down Payment</td>
                <td id="fhaDownPayment">&mdash;</td>
              </tr>
              <tr>
                <td>Closing Costs</td>
                <td id="fhaClosingCostsDisplay">&mdash;</td>
              </tr>
              <tr>
                <td>Prepaids</td>
                <td id="fhaPrepaidsDisplay">&mdash;</td>
              </tr>
              <tr>
                <td>Escrow Reserves</td>
                <td id="fhaEscrowDisplay">&mdash;</td>
              </tr>
              <tr id="fhaUfmipOopRow" style="display:none;">
                <td>UFMIP (out of pocket)</td>
                <td id="fhaUfmipOop">&mdash;</td>
              </tr>
              <tr>
                <td>Seller / Lender Credits</td>
                <td id="fhaCreditsDisplay">&mdash;</td>
              </tr>
              <tr class="fha-total-row">
                <td>Est. Cash to Close</td>
                <td id="fhaCashToClose">&mdash;</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Refi Results (shown in refi mode) — 3-column comparison -->
      <div id="fhaRefiResults" class="fha-refi-only" style="display:none;">
        <div class="fha-results-wrap">
          <table class="fha-results-table fha-compare-table">
            <thead>
              <tr>
                <th class="fha-label-col"></th>
                <th>Rate/Term</th>
                <th>Cash-Out</th>
                <th>Streamline</th>
              </tr>
            </thead>
            <tbody>
              <tr class="fha-section-row"><td colspan="4">Loan Amount</td></tr>
              <tr>
                <td>Max Base Loan</td>
                <td id="fhaRT_maxLoan">&mdash;</td>
                <td id="fhaCO_maxLoan">&mdash;</td>
                <td id="fhaSL_maxLoan">&mdash;</td>
              </tr>
              <tr>
                <td>UFMIP Refund</td>
                <td id="fhaRT_ufmipRefund">&mdash;</td>
                <td id="fhaCO_ufmipRefund">&mdash;</td>
                <td id="fhaSL_ufmipRefund">&mdash;</td>
              </tr>
              <tr>
                <td>New UFMIP (1.75%)</td>
                <td id="fhaRT_ufmip">&mdash;</td>
                <td id="fhaCO_ufmip">&mdash;</td>
                <td id="fhaSL_ufmip">&mdash;</td>
              </tr>
              <tr class="fha-subtotal-row">
                <td>Total Loan</td>
                <td id="fhaRT_totalLoan">&mdash;</td>
                <td id="fhaCO_totalLoan">&mdash;</td>
                <td id="fhaSL_totalLoan">&mdash;</td>
              </tr>
              <tr>
                <td>LTV</td>
                <td id="fhaRT_ltv">&mdash;</td>
                <td id="fhaCO_ltv">&mdash;</td>
                <td id="fhaSL_ltv">&mdash;</td>
              </tr>

              <tr class="fha-section-row"><td colspan="4">Monthly Payment</td></tr>
              <tr>
