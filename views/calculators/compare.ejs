<div class="calc-page">
  <div class="calc-page__header">
    <h1>Loan Comparison</h1>
    <p>Compare up to 4 loan scenarios side by side. Auto-fills from MISMO.</p>
  </div>

  <div class="calc-page__body">

    <!-- ============ Top Controls ============ -->
    <div class="calc-section cmp-controls">
      <div class="cmp-controls__row">
        <div class="cmp-toggle">
          <button type="button" class="cmp-toggle-btn active" data-mode="Purchase">Purchase</button>
          <button type="button" class="cmp-toggle-btn" data-mode="Refinance">Refinance</button>
        </div>
        <label class="form-check cmp-existing-check">
          <input type="checkbox" id="cmpIncludeExisting">
          Include Existing Loan
        </label>
      </div>
      <div class="cmp-controls__row cmp-controls__templates">
        <div class="cmp-template-group">
          <select id="cmpTemplateSelect">
            <option value="">Load Template...</option>
          </select>
          <button type="button" class="btn btn-sm" id="cmpLoadTemplateBtn">Load</button>
          <button type="button" class="btn btn-sm" id="cmpDeleteTemplateBtn" title="Delete selected template">&times;</button>
        </div>
        <button type="button" class="btn btn-sm btn-primary" id="cmpSaveTemplateBtn">Save Template</button>
      </div>
    </div>

    <!-- ============ Shared Info ============ -->
    <div class="calc-section">
      <div class="cmp-info-bar">
        <div class="form-group">
          <label for="cmpBorrower">Borrower(s)</label>
          <input type="text" id="cmpBorrower" placeholder="e.g. John Smith">
        </div>
        <div class="form-group">
          <label for="cmpProperty">Property Address</label>
          <input type="text" id="cmpProperty" placeholder="e.g. 123 Main St">
        </div>
        <div class="form-group">
          <label for="cmpFileNumber">File Number</label>
          <input type="text" id="cmpFileNumber" placeholder="e.g. R008580">
        </div>
        <div class="form-group">
          <label for="cmpPrepDate">Preparation Date</label>
          <input type="date" id="cmpPrepDate">
        </div>
        <div class="form-group">
          <label for="cmpOccupancy">Occupancy</label>
          <select id="cmpOccupancy">
            <option value="Primary">Primary Residence</option>
            <option value="Secondary">Second Home</option>
            <option value="Investment">Investment</option>
          </select>
        </div>
        <div class="form-group">
          <label for="cmpPropType">Property Type</label>
          <select id="cmpPropType">
            <option value="SFR">Single Family</option>
            <option value="Condo">Condo</option>
            <option value="Townhome">Townhome</option>
            <option value="2-4 Unit">2-4 Unit</option>
            <option value="Manufactured">Manufactured</option>
          </select>
        </div>
      </div>
    </div>

    <!-- ============ Comparison Table ============ -->
    <div class="cmp-table-wrap">
      <table class="cmp-table" id="cmpTable">
        <thead>
          <tr id="cmpHeaderRow">
            <th class="cmp-label-col"></th>
            <th class="cmp-col-th" data-col="1">
              <div class="cmp-col-header">
                <input type="text" class="cmp-col-label" id="cmpLabel_1" value="Loan 1">
              </div>
            </th>
            <th class="cmp-add-col" id="cmpAddCol">
              <button type="button" class="btn btn-sm cmp-add-btn" id="cmpAddBtn">+ Add Loan</button>
            </th>
          </tr>
        </thead>
        <tbody id="cmpBody">

          <!-- ═══════ LOAN SUMMARY ═══════ -->
          <tr class="cmp-section-hdr"><td colspan="99">Loan Summary</td></tr>
          <tr data-row="product">
            <td>Product</td>
            <td><input type="text" class="cmp-input u-text-left" id="cmpProduct_1" placeholder="e.g. Conv 30yr Fixed"></td>
          </tr>
          <tr data-row="propertyValue">
            <td>Property Value</td>
            <td><input type="number" class="cmp-input" id="cmpPropertyValue_1" value="0" min="0" step="1000"></td>
          </tr>
          <tr data-row="loanAmount">
            <td>Base Loan Amount</td>
            <td><input type="number" class="cmp-input" id="cmpLoanAmount_1" value="0" min="0" step="1000"></td>
          </tr>
          <tr data-row="fhaUfmip" class="cmp-fha-row">
            <td>FHA UFMIP (1.75%)</td>
            <td>
              <div class="cmp-ufmip-cell">
                <label class="cmp-ufmip-toggle"><input type="checkbox" id="cmpFinanceUfmip_1"> Finance</label>
                <span class="cmp-computed" id="cmpUfmipAmount_1">$0</span>
              </div>
            </td>
          </tr>
          <tr class="cmp-key-row" data-row="totalLoanAmount">
            <td>Total Loan Amount</td>
            <td><span class="cmp-computed cmp-key-value" id="cmpTotalLoanAmount_1">$0</span></td>
          </tr>
          <tr class="cmp-key-row" data-row="rate">
            <td>Interest Rate (%)</td>
            <td><input type="number" class="cmp-input cmp-input--rate" id="cmpRate_1" value="0" min="0" max="20" step="0.125"></td>
          </tr>
          <tr data-row="term">
            <td>Term (Months)</td>
            <td><input type="number" class="cmp-input cmp-input--sm" id="cmpTerm_1" value="360" min="0" max="600" step="1"></td>
          </tr>
          <tr data-row="ltv">
            <td>LTV</td>
            <td><span class="cmp-computed" id="cmpLtv_1">&mdash;</span></td>
          </tr>
          <tr class="cmp-key-row" data-row="monthlyPI">
            <td>Monthly P&amp;I</td>
            <td><span class="cmp-computed cmp-key-value" id="cmpMonthlyPI_1">$0</span></td>
          </tr>

          <!-- ═══════ A. ORIGINATION CHARGES ═══════ -->
          <tr class="cmp-section-hdr"><td colspan="99">A. Origination Charges</td></tr>
          <tr data-row="origFee" data-section="origination">
            <td>Origination Fee</td>
            <td><input type="number" class="cmp-input" id="cmpOrigFee_1" value="0" min="0" step="1"></td>
          </tr>
          <tr data-row="discountPts" data-section="origination">
            <td>Discount Points</td>
            <td><input type="number" class="cmp-input" id="cmpDiscountPts_1" value="0" min="0" step="1"></td>
          </tr>
          <tr data-row="processingFee" data-section="origination">
            <td>Processing Fee</td>
            <td><input type="number" class="cmp-input" id="cmpProcessingFee_1" value="0" min="0" step="1"></td>
          </tr>
          <tr data-row="underwritingFee" data-section="origination">
            <td>Underwriting Fee</td>
            <td><input type="number" class="cmp-input" id="cmpUnderwritingFee_1" value="0" min="0" step="1"></td>
          </tr>
          <tr class="cmp-sub-row" data-row="origTotal" data-section="origination">
            <td>Origination Total</td>
            <td><span class="cmp-computed" id="cmpOrigTotal_1">$0</span></td>
          </tr>

          <!-- ═══════ B. SERVICES YOU CANNOT SHOP FOR ═══════ -->
          <tr class="cmp-section-hdr"><td colspan="99">B. Services You Cannot Shop For</td></tr>
          <tr data-row="appraisalFee" data-section="cannotShop">
            <td>Appraisal</td>
            <td><input type="number" class="cmp-input" id="cmpAppraisalFee_1" value="0" min="0" step="1"></td>
          </tr>
          <tr data-row="creditReportFee" data-section="cannotShop">
            <td>Credit Report</td>
            <td><input type="number" class="cmp-input" id="cmpCreditReportFee_1" value="0" min="0" step="1"></td>
          </tr>
          <tr data-row="floodCert" data-section="cannotShop">
            <td>Flood Certification</td>
            <td><input type="number" class="cmp-input" id="cmpFloodCert_1" value="0" min="0" step="1"></td>
          </tr>
          <tr data-row="taxService" data-section="cannotShop">
            <td>Tax Service Fee</td>
            <td><input type="number" class="cmp-input" id="cmpTaxService_1" value="0" min="0" step="1"></td>
          </tr>
          <tr class="cmp-sub-row" data-row="cannotShopTotal" data-section="cannotShop">
            <td>Cannot-Shop Total</td>
            <td><span class="cmp-computed" id="cmpCannotShopTotal_1">$0</span></td>
          </tr>

          <!-- ═══════ C. SERVICES YOU CAN SHOP FOR ═══════ -->
          <tr class="cmp-section-hdr"><td colspan="99">C. Services You Can Shop For</td></tr>
          <tr data-row="titleSearch" data-section="canShop">
            <td>Title Search / Exam</td>
            <td><input type="number" class="cmp-input" id="cmpTitleSearch_1" value="0" min="0" step="1"></td>
          </tr>
          <tr data-row="titleInsurance" data-section="canShop">
            <td>Title Insurance</td>
            <td><input type="number" class="cmp-input" id="cmpTitleInsurance_1" value="0" min="0" step="1"></td>
          </tr>
          <tr data-row="settlementFee" data-section="canShop">
            <td>Settlement / Closing Fee</td>
            <td><input type="number" class="cmp-input" id="cmpSettlementFee_1" value="0" min="0" step="1"></td>
          </tr>
          <tr data-row="surveyFee" data-section="canShop">
            <td>Survey</td>
            <td><input type="number" class="cmp-input" id="cmpSurveyFee_1" value="0" min="0" step="1"></td>
          </tr>
          <tr data-row="pestInspection" data-section="canShop">
            <td>Pest Inspection</td>
            <td><input type="number" class="cmp-input" id="cmpPestInspection_1" value="0" min="0" step="1"></td>
          </tr>
          <tr class="cmp-sub-row" data-row="canShopTotal" data-section="canShop">
            <td>Can-Shop Total</td>
            <td><span class="cmp-computed" id="cmpCanShopTotal_1">$0</span></td>
          </tr>

          <!-- ═══════ D. TAXES & GOVERNMENT FEES ═══════ -->
          <tr class="cmp-section-hdr"><td colspan="99">D. Taxes &amp; Government Fees</td></tr>
          <tr data-row="recordingFee" data-section="government">
            <td>Recording Fee</td>
            <td><input type="number" class="cmp-input" id="cmpRecordingFee_1" value="0" min="0" step="1"></td>
          </tr>
          <tr data-row="transferTax" data-section="government">
            <td>Transfer Tax</td>
            <td><input type="number" class="cmp-input" id="cmpTransferTax_1" value="0" min="0" step="1"></td>
          </tr>
          <tr class="cmp-sub-row" data-row="govTotal" data-section="government">
            <td>Government Total</td>
            <td><span class="cmp-computed" id="cmpGovTotal_1">$0</span></td>
          </tr>

          <!-- ═══════ E. PREPAIDS ═══════ -->
          <tr class="cmp-section-hdr"><td colspan="99">E. Prepaids</td></tr>
          <tr data-row="prepaidInsurance" data-section="prepaids">
            <td>Homeowners Insurance</td>
            <td><input type="number" class="cmp-input" id="cmpPrepaidInsurance_1" value="0" min="0" step="1"></td>
          </tr>
          <tr data-row="prepaidInterest" data-section="prepaids">
            <td>Prepaid Interest</td>
            <td><input type="number" class="cmp-input" id="cmpPrepaidInterest_1" value="0" min="0" step="1"></td>
          </tr>
          <tr class="cmp-sub-row" data-row="prepaidsTotal" data-section="prepaids">
            <td>Prepaids Total</td>
            <td><span class="cmp-computed" id="cmpPrepaidsTotal_1">$0</span></td>
          </tr>

          <!-- ═══════ F. INITIAL ESCROW ═══════ -->
          <tr class="cmp-section-hdr"><td colspan="99">F. Initial Escrow Deposit</td></tr>
          <tr data-row="escrowTax" data-section="escrow">
            <td>Property Tax</td>
            <td><input type="number" class="cmp-input" id="cmpEscrowTax_1" value="0" min="0" step="1"></td>
          </tr>
          <tr data-row="escrowInsurance" data-section="escrow">
            <td>Homeowners Insurance</td>
            <td><input type="number" class="cmp-input" id="cmpEscrowInsurance_1" value="0" min="0" step="1"></td>
          </tr>
          <tr data-row="escrowMI" data-section="escrow">
            <td>Mortgage Insurance</td>
            <td><input type="number" class="cmp-input" id="cmpEscrowMI_1" value="0" min="0" step="1"></td>
          </tr>
          <tr class="cmp-sub-row" data-row="escrowTotal" data-section="escrow">
            <td>Escrow Total</td>
            <td><span class="cmp-computed" id="cmpEscrowTotal_1">$0</span></td>
          </tr>

          <!-- ═══════ G. OTHER ═══════ -->
          <tr class="cmp-section-hdr"><td colspan="99">G. Other Costs</td></tr>
          <tr data-row="otherFees" data-section="other">
            <td>Other Fees</td>
            <td><input type="number" class="cmp-input" id="cmpOtherFees_1" value="0" min="0" step="1"></td>
          </tr>
          <tr class="cmp-sub-row" data-row="otherTotal" data-section="other">
            <td>Other Total</td>
            <td><span class="cmp-computed" id="cmpOtherTotal_1">$0</span></td>
          </tr>

          <!-- ═══════ TOTAL CLOSING COSTS ═══════ -->
          <tr class="cmp-grand-row" data-row="totalClosing">
            <td>Total Closing Costs (A-G)</td>
            <td><span class="cmp-computed" id="cmpTotalClosing_1">$0</span></td>
          </tr>

          <!-- ═══════ PAYOFFS (refi only) ═══════ -->
          <tr class="cmp-section-hdr cmp-refi-only"><td colspan="99">Payoffs</td></tr>
          <tr data-row="payoff1st" class="cmp-refi-only">
            <td>1st Mortgage Payoff</td>
            <td><input type="number" class="cmp-input" id="cmpPayoff1st_1" value="0" min="0" step="1"></td>
          </tr>
          <tr data-row="payoff2nd" class="cmp-refi-only">
            <td>2nd Mortgage Payoff</td>
            <td><input type="number" class="cmp-input" id="cmpPayoff2nd_1" value="0" min="0" step="1"></td>
          </tr>
          <tr data-row="payoffOther" class="cmp-refi-only">
            <td>Other Payoffs</td>
            <td><input type="number" class="cmp-input" id="cmpPayoffOther_1" value="0" min="0" step="1"></td>
          </tr>
          <tr class="cmp-sub-row cmp-refi-only" data-row="payoffsTotal">
            <td>Total Payoffs</td>
            <td><span class="cmp-computed" id="cmpPayoffsTotal_1">$0</span></td>
          </tr>

          <!-- ═══════ CASH TO CLOSE ═══════ -->
          <tr class="cmp-section-hdr"><td colspan="99">Cash to Close</td></tr>
          <tr data-row="downPayment" class="cmp-purchase-only">
            <td>Down Payment</td>
            <td><input type="number" class="cmp-input" id="cmpDownPayment_1" value="0" min="0" step="1000"></td>
          </tr>
          <tr data-row="earnestMoney" class="cmp-purchase-only">
            <td>Earnest Money (credit)</td>
            <td><input type="number" class="cmp-input" id="cmpEarnestMoney_1" value="0" min="0" step="1"></td>
          </tr>
          <tr data-row="lenderCredits">
            <td>Lender Credits</td>
            <td><input type="number" class="cmp-input" id="cmpLenderCredits_1" value="0" min="0" step="1"></td>
          </tr>
          <tr data-row="sellerConcessions">
            <td>Seller / Agent Concessions</td>
            <td><input type="number" class="cmp-input" id="cmpSellerConcessions_1" value="0" min="0" step="1"></td>
          </tr>
          <tr class="cmp-total-row" data-row="cashToClose">
            <td>Est. Cash to Close</td>
            <td><span class="cmp-key-value" id="cmpCashToClose_1">$0</span></td>
          </tr>

          <!-- ═══════ MONTHLY PAYMENT ═══════ -->
          <tr class="cmp-section-hdr"><td colspan="99">Monthly Payment</td></tr>
          <tr data-row="monthlyPIRow">
            <td>Principal &amp; Interest</td>
            <td><span class="cmp-computed" id="cmpMonthlyPIRow_1">$0</span></td>
          </tr>
          <tr data-row="monthlyTax">
            <td>Property Tax</td>
            <td><input type="number" class="cmp-input" id="cmpMonthlyTax_1" value="0" min="0" step="0.01"></td>
          </tr>
          <tr data-row="monthlyInsurance">
            <td>Homeowners Insurance</td>
            <td><input type="number" class="cmp-input" id="cmpMonthlyInsurance_1" value="0" min="0" step="0.01"></td>
          </tr>
          <tr data-row="monthlyMI">
            <td>Mortgage Insurance</td>
            <td><input type="number" class="cmp-input" id="cmpMonthlyMI_1" value="0" min="0" step="0.01"></td>
          </tr>
          <tr data-row="monthlyHOA">
            <td>HOA</td>
            <td><input type="number" class="cmp-input" id="cmpMonthlyHOA_1" value="0" min="0" step="0.01"></td>
          </tr>
          <tr class="cmp-total-row" data-row="totalMonthly">
            <td>Total Monthly Payment</td>
            <td><span class="cmp-key-value" id="cmpTotalMonthly_1">$0</span></td>
          </tr>

          <!-- ═══════ APR & NOTES ═══════ -->
          <tr class="cmp-section-hdr"><td colspan="99">Additional</td></tr>
          <tr class="cmp-key-row" data-row="APR">
            <td>APR (%)</td>
            <td><input type="number" class="cmp-input cmp-input--rate cmp-computed" id="cmpAPR_1" value="0" min="0" max="100" step="0.001"></td>
          </tr>
          <tr data-row="notes">
            <td>Notes</td>
            <td class="cmp-loan-cell"><textarea class="cmp-notes" id="cmpNotes_1" rows="2" placeholder="Loan notes..."></textarea></td>
          </tr>

        </tbody>
      </table>
    </div>

    <!-- Add Custom Line Item -->
    <div class="cmp-add-item" id="cmpAddItemBar">
      <div class="cmp-add-item__form">
        <select id="cmpNewItemSection" class="cmp-add-item__select">
          <option value="origination">A. Origination</option>
          <option value="cannotShop">B. Cannot Shop</option>
          <option value="canShop">C. Can Shop</option>
          <option value="government">D. Government</option>
          <option value="prepaids">E. Prepaids</option>
          <option value="escrow">F. Escrow</option>
          <option value="other">G. Other</option>
          <option value="monthly">Monthly Payment</option>
        </select>
        <input type="text" id="cmpNewItemName" placeholder="Custom item name...">
        <button type="button" class="btn btn-sm" id="cmpAddItemBtn">+ Add</button>
      </div>
    </div>

    <%- include('../partials/calc-actions') %>

    <div class="cmp-disclaimer">
      <p><em>Your actual rate, payment, and cost could be higher. Get an official Loan Estimate before choosing a loan.</em></p>
    </div>

  </div>

  <div class="calc-page__footer">
    <div class="calc-page__footer-title">Disclaimers</div>
    <p>Information provided reflects estimates only. Actual charges may vary. This is not a commitment to lend.</p>
  </div>
</div>
