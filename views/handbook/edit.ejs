<div class="hb-page">

  <div class="hb-breadcrumb">
    <a href="/handbook">Handbook</a>
    <span class="hb-breadcrumb__sep">/</span>
    <a href="/handbook#<%= section.doc_slug %>"><%= section.doc_title %></a>
    <span class="hb-breadcrumb__sep">/</span>
    <span>Edit: <%= section.title %></span>
  </div>

  <div class="hb-form">
    <h1>Edit Section</h1>

    <form method="POST" action="/handbook/admin/edit/<%= section.id %>">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <div class="form-group">
        <label for="hbTitle">Title</label>
        <input type="text" id="hbTitle" name="title" value="<%= section.title %>" required class="form-control">
      </div>

      <div class="form-group">
        <label for="hbContent">Content</label>
        <textarea id="hbContent" name="content" rows="24" class="form-control hb-form__textarea"><%= section.content %></textarea>
      </div>

      <div class="hb-form__actions">
        <button type="submit" class="btn btn-primary">Save Changes</button>
        <a href="/handbook/<%= section.doc_slug %>/<%= section.slug %>" class="btn">Cancel</a>
      </div>
    </form>

    <hr class="hb-form__divider">

    <form method="POST" action="/handbook/admin/delete/<%= section.id %>" onsubmit="return confirm('Delete this section? This cannot be undone.')">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit" class="btn btn-danger">Delete Section</button>
    </form>
  </div>

</div>
