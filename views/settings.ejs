<div class="calc-page">
  <div class="calc-page__header">
    <h1>Site Settings</h1>
    <p>Configure your logo, site name, and branding that appears across all calculators.</p>
  </div>

  <div class="calc-page__body">
    <% if (saved) { %>
      <div class="alert alert-info u-mb-lg">
        Settings saved successfully.
      </div>
    <% } %>

    <%- include('./partials/settings/_branding') %>

    <%- include('./partials/settings/_lo-photo') %>

    <%- include('./partials/settings/_email-signature') %>

    <%- include('./partials/settings/_theme') %>

    <%- include('./partials/settings/_smtp') %>

    <%- include('./partials/settings/_ai') %>
  </div>
</div>
